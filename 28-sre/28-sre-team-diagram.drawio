00" height="110" as="geometry" /></mxCell><mxCell id="id125" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;fontSize=10;strokeColor=#3498db;" edge="1" parent="1" source="id120" target="id122"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="id126" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;fontSize=10;strokeColor=#3498db;" edge="1" parent="1" source="id120" target="id123"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="id127" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;fontSize=10;strokeColor=#3498db;" edge="1" parent="1" source="id120" target="id124"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="id128" value="Each plan includes:&#10;• Task table per role&#10;• Dependencies map&#10;• Execution order&#10;• Complexity (Low→Critical)&#10;• Priority (P0-P3)&#10;• Effort estimate&#10;• Critical path&#10;• Parallel opportunities" style="shape=note;whiteSpace=wrap;html=1;fillColor=#ffffcc;strokeColor=#d6d600;fontColor=#333333;fontSize=9;fontStyle=0;size=14;" vertex="1" parent="1"><mxGeometry x="1130" y="850" width="180" height="110" as="geometry" /></mxCell><mxCell id="id129" value="WAVE 1.5 — JUDGE EVALUATION + RESEARCH" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#555555;fontSize=14;fontStyle=1;fontColor=#aaaaaa;verticalAlign=top;dashed=1;dashPattern=5 5;arcSize=8;" vertex="1" parent="1"><mxGeometry x="40" y="990" width="1320" height="230" as="geometry" /></mxCell><mxCell id="id130" value="⚖️ JUDGE — Decision Analyst&#10;(Foreground, BLOCKING)&#10;7-Criterion Scoring Rubric&#10;Strategy 25% | Feasibility 20%&#10;Risk 15% | Scale 10% | Innovation 10%&#10;Complete 10% | Efficiency 10%" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e94560;strokeColor=#c81d4e;fontColor=#ffffff;fontSize=12;fontStyle=1;" vertex="1" pa