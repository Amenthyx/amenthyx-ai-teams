{
  "name": "@amenthyx/mission-control",
  "version": "1.0.0",
  "description": "Real-time monitoring dashboard for AI agentic team execution",
  "private": true,
  "bin": {
    "mission-control": "./bin/mission-control.js"
  },
  "scripts": {
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite --config src/client/vite.config.ts",
    "dashboard": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "vite build --config src/client/vite.config.ts",
    "build": "npm run build:server && npm run build:client",
    "start": "node dist/server/index.js",
    "cli": "tsx src/server/cli.ts",
    "scaffold": "bash scaffold/scaffold.sh",
    "generate-config": "tsx scaffold/generate-config.ts",
    "mc:init": "tsx src/server/cli.ts init",
    "mc:start": "tsx src/server/cli.ts start",
    "mc:stop": "tsx src/server/cli.ts stop",
    "mc:status": "tsx src/server/cli.ts status",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "format": "prettier --write src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.18.0",
    "ws": "^8.16.0",
    "better-sqlite3": "^11.0.0",
    "chokidar": "^3.6.0",
    "cors": "^2.8.5",
    "concurrently": "^8.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/ws": "^8.5.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/cors": "^2.8.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "tsx": "^4.7.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "vite": "^5.4.0",
    "@vitejs/plugin-react": "^4.2.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "recharts": "^2.12.0",
    "lucide-react": "^0.400.0",
    "zustand": "^4.5.0",
    "react-router-dom": "^6.22.0",
    "react-window": "^1.8.0",
    "@types/react-window": "^1.8.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
